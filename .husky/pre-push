#!/bin/sh
set -e  # stop on any error

# Go to project root to avoid path issues
cd "$(git rev-parse --show-toplevel)"

echo "🔧 Running ESLint..."
npm run lint

echo "🔍 Running TypeScript check..."
npx tsc --noEmit

echo "🏗️ Running Next.js build check..."
npm run build

echo "✅ All checks passed. Proceeding with push."
